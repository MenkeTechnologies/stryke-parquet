#!/usr/bin/env stryke
# examples/inspect.stk — fast metadata-only summary of a parquet file.
# Run:   s examples/inspect.stk path/to/file.parquet

use Parquet

val $path = $ARGV[0]
die "usage: inspect.stk PATH.parquet\n" unless defined $path

val $info = Parquet::inspect $path
p sprintf("rows=%d  row_groups=%d  cols=%d  size=%d (%.1f%% of raw)",
          $info->{num_rows}, $info->{num_row_groups}, $info->{num_columns},
          $info->{file_size},
          100.0 * ($info->{compression_ratio} // 0))
p "created by: " . ($info->{created_by} // "?")
p "compressions:"
for val $k (sort keys %{ $info->{compressions} }) {
    p "  $k → $info->{compressions}{$k} column-chunks"
}
