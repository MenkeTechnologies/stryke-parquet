## t/test_parquet.stk — assertion tests for the stryke `Parquet` package.
##
## Uses stryke's native test framework (`assert_*` + `test_run`).
## Self-contained — generates a fixed-shape demo parquet via the cdylib's
## `_mkdemo` export, then exercises every diagnostic op against it.
## Requires the cdylib to be loaded (install once with `s pkg install -g .`).

use Parquet

# ── permission-free: cdylib reachable ───────────────────────────────
val $version = Parquet::version()
assert_ok $version, "Parquet::version returns truthy (cdylib loaded)"

# ── generate demo file ──────────────────────────────────────────────
val $tmp = "/tmp/stryke-parquet-test-$$"
mkdir $tmp unless -d $tmp
val $path  = "$tmp/demo.parquet"
val $path2 = "$tmp/demo-snap.parquet"
Parquet::_mkdemo($path)

# ── count ───────────────────────────────────────────────────────────
assert_eq Parquet::count($path), 5, "count: 5 rows"

# ── inspect ─────────────────────────────────────────────────────────
val $info = Parquet::inspect($path)
assert_eq $info->{num_rows}, 5, "inspect: num_rows=5"
assert_eq $info->{num_columns}, 3, "inspect: num_columns=3"

# ── schema ──────────────────────────────────────────────────────────
val $sch = Parquet::schema($path)
assert_eq $sch->{num_fields}, 3, "schema: num_fields=3"
assert_eq scalar(@{$sch->{fields}}), 3, "schema: fields array has 3 entries"

# ── head 2 ──────────────────────────────────────────────────────────
val @first = Parquet::head($path, n => 2)
assert_eq scalar(@first), 2, "head(2): 2 rows"
assert_eq $first[0]->{name}, "alice", "head(2): first.name=alice"

# ── tail 2 ──────────────────────────────────────────────────────────
val @last = Parquet::tail($path, n => 2)
assert_eq scalar(@last), 2, "tail(2): 2 rows"
assert_eq $last[-1]->{name}, "eve", "tail(2): last.name=eve"

# ── reverse: all rows in reverse file order ─────────────────────────
val @rev = Parquet::reverse($path)
assert_eq scalar(@rev), 5,           "reverse: returns every row"
assert_eq $rev[0]->{name},  "eve",   "reverse: last-written row comes first"
assert_eq $rev[-1]->{name}, "alice", "reverse: first-written row comes last"
val @revp = Parquet::reverse($path, columns => ["name"])
assert_eq $revp[0]->{name},  "eve",   "reverse: honors column projection"

# ── gather: rows by explicit index list ─────────────────────────────
val @g = Parquet::gather($path, [4, 0, 0])
assert_eq scalar(@g), 3,            "gather: row count = index count"
assert_eq $g[0]->{name}, "eve",     "gather: index 4 first"
assert_eq $g[1]->{name}, "alice",   "gather: index 0 second"
assert_eq $g[2]->{name}, "alice",   "gather: repeated index emits the row twice"
val @gp = Parquet::gather($path, [4], columns => ["name"])
assert_eq $gp[0]->{name}, "eve",    "gather: honors column projection"
assert_dies fn { Parquet::gather($path, [0, 5]) }, "gather: index 5 out of range for 5 rows dies"

# ── top_k: the k rows with the largest/smallest values in a column ───
val @tk = Parquet::top_k($path, "id", 2)
assert_eq scalar(@tk), 2,           "top_k: keeps k rows"
assert_eq $tk[0]->{name}, "eve",    "top_k: largest id first (eve=5)"
assert_eq $tk[1]->{name}, "dave",   "top_k: second largest (dave=4)"
val @bk = Parquet::top_k($path, "id", 2, descending => 0)
assert_eq $bk[0]->{name}, "alice",  "top_k descending=>0: smallest id first (bottom_k)"
# score has a NULL (carol) — it must never take a top slot.
val @ts = Parquet::top_k($path, "score", 5)
assert_eq $ts[-1]->{name}, "carol", "top_k: the null-score row sorts last"
assert_eq scalar(Parquet::top_k($path, "id", 100)), 5, "top_k: k caps at the row count"
assert_dies fn { Parquet::top_k($path, "nope", 1) }, "top_k: unknown column dies"

# ── value_counts: frequency per distinct value ──────────────────────
val $vcsrc = "$tmp/vc.ndjson"
spurt($vcsrc, qq({"c":"red"}\n{"c":"blue"}\n{"c":"red"}\n{"c":"green"}\n{"c":"blue"}\n{"c":"red"}\n))
val $vcpq = "$tmp/vc.parquet"
Parquet::from_json($vcsrc, $vcpq)
val @vc = Parquet::value_counts($vcpq, "c")
assert_eq scalar(@vc), 3,                            "value_counts: 3 distinct values"
assert_eq join(",", map { $_->{value} } @vc), "red,blue,green", "value_counts: distinct values sorted by count desc"
assert_eq join(",", map { $_->{count} } @vc), "3,2,1",          "value_counts: frequency of each value"

# ── slice: arbitrary offset window ──────────────────────────────────
val @win = Parquet::slice($path, offset => 1, length => 2)
assert_eq scalar(@win), 2, "slice(1,2): 2 rows"
assert_eq $win[0]->{id}, 2, "slice(1,2): first row is id 2 (offset skips row 1)"
assert_eq $win[1]->{id}, 3, "slice(1,2): second row is id 3"
val @rest = Parquet::slice($path, offset => 3)
assert_eq scalar(@rest), 2, "slice(offset=3, no length): runs to the end"
assert_eq $rest[0]->{id}, 4, "slice(offset=3): starts at id 4"
assert_eq scalar(Parquet::slice($path, offset => 10, length => 3)), 0, "slice past the end yields no rows"
assert_eq scalar(Parquet::slice($path)), 5, "slice with no offset/length is the whole file"
# Projection works like head.
assert_ok !exists((Parquet::slice($path, offset => 0, length => 1, columns => ["id"]))[0]->{name}), "slice: columns projection drops unlisted fields"

# ── rowgroups ───────────────────────────────────────────────────────
val @rgs = Parquet::rowgroups($path)
assert_ge scalar(@rgs), 1, "rowgroups: ≥1 group"
assert_eq $rgs[0]->{num_rows}, 5, "rowgroups[0]: 5 rows"

# ── row_group_summary: footer-only sizing rollup ────────────────────
val $rgs = Parquet::row_group_summary($path)
assert_ge $rgs->{num_row_groups}, 1,   "row_group_summary: at least one group"
assert_eq $rgs->{total_rows}, 5,       "row_group_summary: total rows"
assert_ok $rgs->{rows_per_group}{mean} > 0, "row_group_summary: mean rows per group"
assert_ok $rgs->{compressed_bytes_per_group}{min} <= $rgs->{compressed_bytes_per_group}{max}, "row_group_summary: byte min <= max"
assert_dies fn { Parquet::row_group_summary("/tmp/nope-$$.parquet") }, "row_group_summary: dies on a missing file"

# ── stats all columns ───────────────────────────────────────────────
val @stats = Parquet::stats($path)
assert_eq scalar(@stats), 3, "stats: one row per column"

# ── stats single column with null count ─────────────────────────────
val @score_stats = Parquet::stats($path, column => "score")
assert_eq scalar(@score_stats), 1, "stats(score): 1 row"
assert_eq $score_stats[0]->{null_count}, 1, "stats(score): null_count=1"

# ── column projection in head (projects at parquet level) ──────────
val @proj = Parquet::head($path, n => 1, columns => ["id", "name"])
assert_ok defined $proj[0]->{id}, "head projection: id present"
assert_ok defined $proj[0]->{name}, "head projection: name present"
assert_ok !exists $proj[0]->{score}, "head projection: score excluded"

# ── compress to snappy ──────────────────────────────────────────────
val $cr = Parquet::compress($path, $path2, codec => "snappy")
assert_eq $cr->{rows}, 5, "compress: rows=5"
assert_eq $cr->{num_rows}, 5, "compress: num_rows=5 (alias of rows)"
assert_eq $cr->{compression}, "snappy", "compress: codec=snappy"
assert_ok -e $path2, "compress: output file exists"

# ── select: project a column subset into a new file ─────────────────
val $proj = "$tmp/demo-proj.parquet"
val $sel = Parquet::select($path, $proj, ["id", "score"])
assert_eq $sel->{rows}, 5,                      "select: all 5 rows preserved"
assert_eq join(",", @{ $sel->{columns} }), "id,score", "select: only id+score kept"
assert_eq Parquet::schema($proj)->{num_fields}, 2, "select: pruned file has 2 fields (name dropped)"
assert_dies fn { Parquet::select($path, $proj, ["id", "nope"]) }, "select: dies on an unknown column"

# ── drop: complement of select (keep all but the named columns) ─────
val $dropped = "$tmp/demo-drop.parquet"
val $dr = Parquet::drop($path, $dropped, ["name"])
assert_eq $dr->{rows}, 5,                            "drop: all 5 rows preserved"
assert_eq join(",", @{ $dr->{columns} }), "id,score", "drop: name removed, rest in file order"
assert_eq Parquet::schema($dropped)->{num_fields}, 2, "drop: file has 2 fields (name dropped)"
assert_dies fn { Parquet::drop($path, $dropped, ["nope"]) },           "drop: dies on an unknown column"
assert_dies fn { Parquet::drop($path, $dropped, ["id","name","score"]) }, "drop: refuses to drop every column"

# ── rename: relabel columns (the third column-op alongside select/drop) ──
val $renamed = "$tmp/demo-rename.parquet"
val $rn = Parquet::rename($path, $renamed, { name => "label", score => "points" })
assert_eq $rn->{rows}, 5,                                       "rename: all 5 rows preserved"
assert_eq join(",", @{ $rn->{columns} }), "id,label,points",   "rename: only mapped names change, order kept"
assert_eq join(",", @{ Parquet::column_names($renamed) }), "id,label,points", "rename: new names land in the file schema"
assert_dies fn { Parquet::rename($path, $renamed, { nope => "x" }) },  "rename: dies on an unknown column"
assert_dies fn { Parquet::rename($path, $renamed, { id => "name" }) }, "rename: rejects a name collision"

# ── hstack: column-wise counterpart of merge ────────────────────────
val $hs_l = "$tmp/demo-hs-l.parquet"
val $hs_r = "$tmp/demo-hs-r.parquet"
Parquet::select($path, $hs_l, ["id"])
Parquet::select($path, $hs_r, ["name"])
val $hs = Parquet::hstack($hs_l, $hs_r, "$tmp/demo-hs.parquet")
assert_eq $hs->{rows}, 5,                              "hstack: row count preserved"
assert_eq join(",", @{ $hs->{columns} }), "id,name",  "hstack: src columns then other columns"
assert_eq Parquet::schema("$tmp/demo-hs.parquet")->{num_fields}, 2, "hstack: combined file has both columns"
assert_dies fn { Parquet::hstack($hs_l, $hs_l, "$tmp/demo-hs-dup.parquet") }, "hstack: rejects a duplicate column name"

# ── filter: rows matching column OP value ───────────────────────────
val @fgt = Parquet::filter($path, "id", "gt", value => 3)
assert_eq scalar(@fgt), 2,           "filter(id > 3): 2 rows"
assert_eq $fgt[0]->{name}, "dave",   "filter(id > 3): first is dave (id 4)"
val @feq = Parquet::filter($path, "name", "eq", value => "carol")
assert_eq scalar(@feq), 1,           "filter(name == carol): 1 row"
assert_eq $feq[0]->{id}, 3,          "filter(name == carol): id 3"
val @fnull = Parquet::filter($path, "score", "is_null")
assert_eq scalar(@fnull), 1,         "filter(score is_null): 1 row (carol)"
assert_eq $fnull[0]->{name}, "carol","filter(score is_null): carol has the null score"
val @fnn = Parquet::filter($path, "score", "is_not_null")
assert_eq scalar(@fnn), 4,           "filter(score is_not_null): 4 rows"
assert_dies fn { Parquet::filter($path, "id", "gt") }, "filter: a comparison op without a value dies"

# ── where_count: count-only predicate ───────────────────────────────
assert_eq Parquet::where_count($path, "id", "ge", value => 3), 3, "where_count(id >= 3): 3"
assert_eq Parquet::where_count($path, "id", "lt", value => 1), 0, "where_count(id < 1): 0"

# ── filter_to: write only matching rows to a new file ───────────────
val $fpq = "$tmp/demo-filter.parquet"
val $ft = Parquet::filter_to($path, $fpq, "id", "gt", value => 3)
assert_eq $ft->{rows}, 2,            "filter_to(id > 3): 2 rows written"
assert_eq Parquet::count($fpq), 2,   "filter_to: output file holds 2 rows"
assert_dies fn { Parquet::filter_to($path, $fpq, "id", "gt", value => 999) }, "filter_to: empty result dies"

# ── distinct: unique rows ───────────────────────────────────────────
val @dist = Parquet::distinct($vcpq, columns => ["c"])
assert_eq scalar(@dist), 3,          "distinct(c): 3 unique colors"

# ── sort: order by a column ─────────────────────────────────────────
val @sd = Parquet::sort($path, "id", descending => 1)
assert_eq $sd[0]->{id}, 5,           "sort(id desc): id 5 first"
assert_eq $sd[-1]->{id}, 1,          "sort(id desc): id 1 last"
val @ss = Parquet::sort($path, "score")
assert_eq $ss[-1]->{name}, "carol",  "sort(score asc): null score (carol) sorts last"

# ── column: extract one field as a flat list ────────────────────────
val @ids = Parquet::column($path, "id")
assert_eq scalar(@ids), 5,           "column(id): 5 values"
assert_eq join(",", @ids), "1,2,3,4,5", "column(id): the id values in file order"
assert_dies fn { Parquet::column($path, "nope") }, "column: unknown column dies"

# ── sum: numeric column total ───────────────────────────────────────
assert_eq Parquet::sum($path, "id"), 15, "sum(id): 1+2+3+4+5 = 15"

# ── describe: per-column numeric summary ────────────────────────────
val $desc = Parquet::describe($path)
assert_eq $desc->{num_rows}, 5,      "describe: 5 rows"
val @dscore = grep { $_->{column} eq "score" } @{ $desc->{columns} }
assert_eq $dscore[0]->{count}, 4,        "describe(score): 4 non-null"
assert_eq $dscore[0]->{null_count}, 1,   "describe(score): 1 null"

# ── group_by: aggregate per group ───────────────────────────────────
val $gpq = "$tmp/grp.ndjson"
spurt($gpq, qq({"r":"us","a":10}\n{"r":"eu","a":20}\n{"r":"us","a":30}\n))
val $gparq = "$tmp/grp.parquet"
Parquet::from_json($gpq, $gparq)
val @gc = Parquet::group_by($gparq, "r")
assert_eq scalar(@gc), 2,            "group_by(r): 2 groups"
assert_eq $gc[0]->{key}, "eu",       "group_by(r): groups sorted by key asc (eu first)"
assert_eq $gc[1]->{count}, 2,        "group_by(r): us has 2 rows"
val @gs = Parquet::group_by($gparq, "r", agg => "a", func => "sum")
assert_eq $gs[1]->{value}, 40,       "group_by(r, sum a): us = 10+30 = 40"

# ── random_sample: reproducible random rows ─────────────────────────
val @r1 = Parquet::random_sample($path, n => 3, seed => 7)
val @r2 = Parquet::random_sample($path, n => 3, seed => 7)
assert_eq scalar(@r1), 3,                          "random_sample(n=3): 3 rows"
assert_eq join(",", map { $_->{id} } @r1), join(",", map { $_->{id} } @r2), "random_sample: same seed → same rows"
assert_eq scalar(Parquet::random_sample($path, n => 100)), 5, "random_sample: n caps at the row count"

# ── to_ndjson: parquet → NDJSON file ────────────────────────────────
val $ndout = "$tmp/demo.ndjson"
val $nd = Parquet::to_ndjson($path, $ndout)
assert_eq $nd->{rows}, 5,            "to_ndjson: 5 rows written"
assert_ok -e $ndout,                 "to_ndjson: output file exists"

# ── repartition: change row-group sizing ────────────────────────────
val $rpq = "$tmp/demo-repart.parquet"
val $rp = Parquet::repartition($path, $rpq, row_group => 2)
assert_eq $rp->{rows}, 5,            "repartition: all 5 rows preserved"
assert_eq $rp->{num_row_groups}, 3, "repartition(row_group=2): 5 rows → 3 groups"

# ── dtypes: Arrow logical types ─────────────────────────────────────
val $dt = Parquet::dtypes($path)
assert_eq $dt->{num_fields}, 3,      "dtypes: 3 fields"
val @dtid = grep { $_->{name} eq "id" } @{ $dt->{columns} }
assert_eq $dtid[0]->{dtype}, "Int64", "dtypes(id): Int64"

# ── min / max / mean: scalar reducers ───────────────────────────────
# demo score = 1.5, 2.0, null, 3.25, 4.0 (null skipped).
assert_eq Parquet::min($path, "score"), 1.5,    "min(score): 1.5"
assert_eq Parquet::max($path, "score"), 4.0,    "max(score): 4.0"
assert_eq Parquet::mean($path, "score"), 2.6875, "mean(score): (1.5+2+3.25+4)/4"
assert_eq Parquet::min($path, "id"), 1,         "min(id): 1"
assert_eq Parquet::max($path, "id"), 5,         "max(id): 5"
assert_dies fn { Parquet::min($path, "nope") }, "min: unknown column dies"

# ── n_unique: distinct value count ──────────────────────────────────
# names are all distinct (5); ids all distinct (5).
assert_eq Parquet::n_unique($path, "name"), 5,  "n_unique(name): 5"
assert_eq Parquet::n_unique($path, "id"), 5,    "n_unique(id): 5"
# score has 4 non-null distinct + 1 null group → 5 with nulls, 4 without.
assert_eq Parquet::n_unique($path, "score"), 5,                       "n_unique(score): 5 incl. null group"
assert_eq Parquet::n_unique($path, "score", include_nulls => 0), 4,  "n_unique(score, no nulls): 4"

# ── quantile / median: numeric percentile ───────────────────────────
# score non-null sorted = [1.5, 2.0, 3.25, 4.0].
assert_eq Parquet::quantile($path, "score", q => 0), 1.5,   "quantile(score, 0): min"
assert_eq Parquet::quantile($path, "score", q => 1), 4.0,   "quantile(score, 1): max"
assert_eq Parquet::median($path, "score"), 2.625,           "median(score): (2.0+3.25)/2"
assert_dies fn { Parquet::quantile($path, "score", q => 2) }, "quantile: q out of range dies"

# ── with_row_index: prepend a 0-based index column ──────────────────
val $ripq = "$tmp/demo-rowindex.parquet"
val $ri = Parquet::with_row_index($path, $ripq)
assert_eq $ri->{rows}, 5,                "with_row_index: 5 rows"
assert_eq $ri->{name}, "index",          "with_row_index: default name 'index'"
assert_eq $ri->{columns}[0], "index",    "with_row_index: index column leads"
val @ridx = Parquet::column($ripq, "index")
assert_eq join(",", @ridx), "0,1,2,3,4", "with_row_index: index is 0..4 in file order"
assert_dies fn { Parquet::with_row_index($path, $ripq, name => "id") }, "with_row_index: name collision dies"

# ── schema_diff: compare two file schemas ───────────────────────────
val $sd_same = Parquet::schema_diff($path, $path)
assert_ok $sd_same->{equal},             "schema_diff(self): equal"
# the row-indexed file adds 'index' vs the original.
val $sd = Parquet::schema_diff($path, $ripq)
assert_ok !$sd->{equal},                 "schema_diff(orig, indexed): not equal"
assert_eq $sd->{added}[0], "index",      "schema_diff: 'index' added in the indexed file"
assert_eq $sd->{other_only}, 1,          "schema_diff: one column only in 'other'"

# cleanup
unlink $ripq if -e $ripq
unlink $path    if -e $path
unlink $path2   if -e $path2
unlink $proj    if -e $proj
unlink $dropped if -e $dropped
unlink $fpq     if -e $fpq
unlink $ndout   if -e $ndout
unlink $rpq     if -e $rpq
rmdir $tmp   if -d $tmp

test_run
