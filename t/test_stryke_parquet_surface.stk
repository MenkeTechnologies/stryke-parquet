## t/test_stryke_parquet_surface.stk — wrapper-completeness pin.
##
## Asserts every public `fn X::Y::name` declared in lib/*.stk is
## reachable via `use` at runtime. Uses `exists &X::Y::name` to
## probe the symbol table without invoking the sub.
##
## Catches:
##   * a wrapper sub deleted from lib/ but still referenced elsewhere
##   * a sub-package file dropped from the install layout
##   * `use Foo::Bar` failing to chase into lib/Bar.stk
##   * an installed-package entry whose namespace bridge is broken
##
## Permission-free — no service, no creds, no live daemon. Private
## helpers (`_` prefix) are implementation detail and are NOT
## asserted, so refactoring internals stays free.

use Parquet

# ── Parquet.stk ──────────────────────────────────────────────
assert_ok exists &Parquet::version, "Parquet::version exists"
assert_ok exists &Parquet::inspect, "Parquet::inspect exists"
assert_ok exists &Parquet::schema, "Parquet::schema exists"
assert_ok exists &Parquet::count, "Parquet::count exists"
assert_ok exists &Parquet::rowgroups, "Parquet::rowgroups exists"
assert_ok exists &Parquet::row_group_summary, "Parquet::row_group_summary exists"
assert_ok exists &Parquet::stats, "Parquet::stats exists"
assert_ok exists &Parquet::head, "Parquet::head exists"
assert_ok exists &Parquet::tail, "Parquet::tail exists"
assert_ok exists &Parquet::reverse, "Parquet::reverse exists"
assert_ok exists &Parquet::gather, "Parquet::gather exists"
assert_ok exists &Parquet::top_k, "Parquet::top_k exists"
assert_ok exists &Parquet::value_counts, "Parquet::value_counts exists"
assert_ok exists &Parquet::slice, "Parquet::slice exists"
assert_ok exists &Parquet::to_json, "Parquet::to_json exists"
assert_ok exists &Parquet::stream, "Parquet::stream exists"
assert_ok exists &Parquet::to_csv, "Parquet::to_csv exists"
assert_ok exists &Parquet::compress, "Parquet::compress exists"
assert_ok exists &Parquet::column_names, "Parquet::column_names exists"
assert_ok exists &Parquet::column_count, "Parquet::column_count exists"
assert_ok exists &Parquet::is_empty, "Parquet::is_empty exists"

# ── Parquet.stk write paths ──
assert_ok exists &Parquet::from_csv, "Parquet::from_csv exists"
assert_ok exists &Parquet::from_json, "Parquet::from_json exists"
assert_ok exists &Parquet::merge, "Parquet::merge exists"
assert_ok exists &Parquet::hstack, "Parquet::hstack exists"
assert_ok exists &Parquet::select, "Parquet::select exists"
assert_ok exists &Parquet::drop, "Parquet::drop exists"
assert_ok exists &Parquet::rename, "Parquet::rename exists"

assert_ok exists &Parquet::write, "Parquet::write exists"
assert_ok exists &Parquet::metadata, "Parquet::metadata exists"

assert_ok exists &Parquet::write_partitioned, "Parquet::write_partitioned exists"

# ── Parquet.stk footer diagnostics ──
assert_ok exists &Parquet::validate, "Parquet::validate exists"
assert_ok exists &Parquet::column_chunk_stats, "Parquet::column_chunk_stats exists"
assert_ok exists &Parquet::size_report, "Parquet::size_report exists"
assert_ok exists &Parquet::null_summary, "Parquet::null_summary exists"
assert_ok exists &Parquet::encoding_summary, "Parquet::encoding_summary exists"
assert_ok exists &Parquet::bloom_filter_summary, "Parquet::bloom_filter_summary exists"
assert_ok exists &Parquet::sorting_columns_summary, "Parquet::sorting_columns_summary exists"
assert_ok exists &Parquet::sample, "Parquet::sample exists"
assert_ok exists &Parquet::features, "Parquet::features exists"

# ── Parquet.stk row predicates / reshaping (polars-style) ──
assert_ok exists &Parquet::filter, "Parquet::filter exists"
assert_ok exists &Parquet::where_count, "Parquet::where_count exists"
assert_ok exists &Parquet::filter_to, "Parquet::filter_to exists"
assert_ok exists &Parquet::distinct, "Parquet::distinct exists"
assert_ok exists &Parquet::sort, "Parquet::sort exists"
assert_ok exists &Parquet::column, "Parquet::column exists"
assert_ok exists &Parquet::sum, "Parquet::sum exists"
assert_ok exists &Parquet::describe, "Parquet::describe exists"
assert_ok exists &Parquet::group_by, "Parquet::group_by exists"
assert_ok exists &Parquet::random_sample, "Parquet::random_sample exists"
assert_ok exists &Parquet::to_ndjson, "Parquet::to_ndjson exists"
assert_ok exists &Parquet::repartition, "Parquet::repartition exists"
assert_ok exists &Parquet::dtypes, "Parquet::dtypes exists"

# ── Parquet.stk scalar reducers / quantiles ──
assert_ok exists &Parquet::min, "Parquet::min exists"
assert_ok exists &Parquet::max, "Parquet::max exists"
assert_ok exists &Parquet::mean, "Parquet::mean exists"
assert_ok exists &Parquet::n_unique, "Parquet::n_unique exists"
assert_ok exists &Parquet::quantile, "Parquet::quantile exists"
assert_ok exists &Parquet::median, "Parquet::median exists"

# ── Parquet.stk reshaping that produces files ──
assert_ok exists &Parquet::with_row_index, "Parquet::with_row_index exists"
assert_ok exists &Parquet::schema_diff, "Parquet::schema_diff exists"
test_run
