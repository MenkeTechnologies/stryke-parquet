## t/test_stryke_parquet_surface.stk — wrapper-completeness pin.
##
## Asserts every public `fn X::Y::name` declared in lib/*.stk is
## reachable via `use` at runtime. Uses `exists &X::Y::name` to
## probe the symbol table without invoking the sub.
##
## Catches:
##   * a wrapper sub deleted from lib/ but still referenced elsewhere
##   * a sub-package file dropped from the install layout
##   * `use Foo::Bar` failing to chase into lib/Bar.stk
##   * an installed-package entry whose namespace bridge is broken
##
## Permission-free — no service, no creds, no live daemon. Private
## helpers (`_` prefix) are implementation detail and are NOT
## asserted, so refactoring internals stays free.

use Parquet

# ── Parquet.stk ──────────────────────────────────────────────
assert_ok exists &Parquet::version, "Parquet::version exists"
assert_ok exists &Parquet::inspect, "Parquet::inspect exists"
assert_ok exists &Parquet::schema, "Parquet::schema exists"
assert_ok exists &Parquet::count, "Parquet::count exists"
assert_ok exists &Parquet::rowgroups, "Parquet::rowgroups exists"
assert_ok exists &Parquet::stats, "Parquet::stats exists"
assert_ok exists &Parquet::head, "Parquet::head exists"
assert_ok exists &Parquet::tail, "Parquet::tail exists"
assert_ok exists &Parquet::to_json, "Parquet::to_json exists"
assert_ok exists &Parquet::stream, "Parquet::stream exists"
assert_ok exists &Parquet::to_csv, "Parquet::to_csv exists"
assert_ok exists &Parquet::compress, "Parquet::compress exists"
assert_ok exists &Parquet::column_names, "Parquet::column_names exists"
assert_ok exists &Parquet::column_count, "Parquet::column_count exists"
assert_ok exists &Parquet::is_empty, "Parquet::is_empty exists"

# ── Parquet.stk write paths ──
assert_ok exists &Parquet::from_csv, "Parquet::from_csv exists"
assert_ok exists &Parquet::from_json, "Parquet::from_json exists"
assert_ok exists &Parquet::merge, "Parquet::merge exists"

test_run
